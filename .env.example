# Copy this file to .env and fill in your values

# Turso (production); leave unset for local SQLite file
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Session signing secret (any long random string)
SESSION_SECRET=change-me-in-production

# Web Push (generate via: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Metered.ca TURN server (optional; without these, only Google STUN is used)
# Sign up at https://www.metered.ca — free tier gives 500 MB/month of TURN relay
METERED_APP_NAME=
METERED_API_KEY=
